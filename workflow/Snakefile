rule its_extraction:
    input:
        contigs = final_contigs
    output:
        full = "03.post-processing/ITS_extraction/{sample}/{sample}.full.fasta",
        its1 = "03.post-processing/ITS_extraction/{sample}/{sample}.ITS1.fasta",
        its2 = "03.post-processing/ITS_extraction/{sample}/{sample}.ITS2.fasta",
        summary = "03.post-processing/ITS_extraction/{sample}/{sample}.summary.txt"
    params:
        basename = "03.post-processing/ITS_extraction/{sample}/{sample}"
    resources:
        cpus = min(CPUS, 24)
    conda:
        "envs/itsx.yaml"
    message:
        "--- ITS marker extraction from contigs. ---"
    log:
        "logs/its_extraction_{sample}.log"
    priority: 8
    shell:
        """
        set -euo pipefail
        mkdir -p $(dirname "{params.basename}")

        temp_dir="{params.basename}.ITSx_tmp"
        rm -rf "$temp_dir"
        mkdir -p "$temp_dir"
        trap 'rm -rf "$temp_dir"' EXIT

        ITSx \
            -i {input.contigs} \
            -o {params.basename} \
            --temp "$temp_dir" \
            --preserve T \
            --only_full F \
            --graphical F \
            --complement T \
            --positions F \
            --not_found F \
            -E 0.001 \
            --plus T \
            --nhmmer T \
            --cpu {resources.cpus} > {log} 2>&1
        """


rule its_classification:
    input:
        its1 = "03.post-processing/ITS_extraction/{sample}/{sample}.ITS1.fasta",
        its2 = "03.post-processing/ITS_extraction/{sample}/{sample}.ITS2.fasta",
        its_db = UNITE_FASTA
    output:
        its1_tax = "03.post-processing/ITS_extraction/{sample}/{sample}_ITS1_taxonomy.txt",
        its2_tax = "03.post-processing/ITS_extraction/{sample}/{sample}_ITS2_taxonomy.txt"
    params:
        cutoff = ITS_TAXONOMY_CUTOFF
    resources:
        cpus = min(CPUS, 24)
    conda:
        "envs/vsearch.yaml"
    message:
        "--- VSEARCH: Classifying ITS sequences using UNITE db. ---"
    log:
        "logs/classify_its_{sample}.log"
    priority: 7
    shell:
        """
        if [ -s {input.its1} ]; then
            vsearch \
                --sintax {input.its1} \
                --db {input.its_db} \
                --tabbedout {output.its1_tax} \
                --sintax_cutoff {params.cutoff} \
                --threads {resources.cpus} >> {log} 2>&1
        else
            echo "ITS1 FASTA file is empty for sample {wildcards.sample}. Skipping classification." >> {log} 2>&1
            touch {output.its1_tax}
        fi

        if [ -s {input.its2} ]; then
            vsearch \
                --sintax {input.its2} \
                --db {input.its_db} \
                --tabbedout {output.its2_tax} \
                --sintax_cutoff {params.cutoff} \
                --threads {resources.cpus} >> {log} 2>&1
        else
            echo "ITS2 FASTA file is empty for sample {wildcards.sample}. Skipping classification." >> {log} 2>&1
            touch {output.its2_tax}
        fi
        """


rule multiqc:
    input:
        nanoplot_raw_dir = expand("01.pre-processing/read_qc/{sample}/raw_read_qc", sample=CHECK_SAMPLES),
        nanoplot_filt_dir = expand("01.pre-processing/read_qc/{sample}/filt_read_qc", sample=CHECK_SAMPLES),
        qualimap_dir = expand("03.post-processing/mapping_evaluation/{sample}", sample=CHECK_SAMPLES),
        busco_dir = expand("03.post-processing/completeness_evaluation/{sample}", sample=CHECK_SAMPLES)
    output:
        multiqc_dir = directory("report"),
        multiqc_yaml = temp("report/multiqc_config.yaml")
    conda:
        "envs/multiqc.yaml"
    message:
        "--- MultiQC: Aggregate results. ---"
    log:
        "logs/multiqc.log"
    priority: 7
    shell:
        r"""
        mkdir -p {output.multiqc_dir}

        printf "%s\n" "show_analysis_paths: False" "show_analysis_time: False" > {output.multiqc_yaml}

        cat >> {output.multiqc_yaml} << 'EOF'
sample_names_replace_regex: true
sample_names_replace_exact: true

sample_names_replace:
  '^(?:.* \| )?01\.pre-processing \| read_qc \| *([^|]+?) *\| raw_read_qc \| *([^|]+?) *$': 'NanoPlot raw read QC | \2'
  '^(?:.* \| )?01\.pre-processing \| read_qc \| *([^|]+?) *\| filt_read_qc \| *([^|]+?) *$': 'NanoPlot filtered read QC | \2'
  '^(?:.* \| )?03\.post-processing \| mapping_evaluation \| *([^|]+?) *\| *([^|]+?)_map *$': 'mapping QC | \2'
  '^(?:.* \| )?03\.post-processing \| mapping_evaluation \| *([^|]+?) *\| raw_data$': 'mapping QC | \1'
  '^(?:.* \| )?03\.post-processing \| mapping_evaluation \| *([^|]+?) *\| raw_data_qualimapReport \| *\1$': 'mapping QC | \1'
  '^(?:.* \| )?03\.post-processing \| completeness_evaluation \| *([^|]+?) *\| short_summary\.(?:generic|specific)\.([^.]+_odb(?:10|12))\.\1$': 'BUSCO completeness QC (\2) | \1'
  '^([^| ]+) \| \1_map$': 'mapping QC | \1'
  '^([^| ]+) \| raw_data$': 'mapping QC | \1'
  '^([^| ]+) \| raw_data_qualimapReport \| \1$': 'mapping QC | \1'
  '^([^| ]+) \| short_summary\.(?:generic|specific)\.([^.]+_odb(?:10|12))\.\1$': 'BUSCO completeness QC (\2) | \1'
EOF

        multiqc \
            --ignore '*NanoStats_post_filtering.txt' \
            --config {output.multiqc_yaml} \
            --outdir {output.multiqc_dir} \
            -d \
            {input.busco_dir} \
            {input.qualimap_dir} \
            {input.nanoplot_raw_dir} \
            {input.nanoplot_filt_dir} > {log} 2>&1
        """


rule funannotate_db:
    output:
        db_info = os.path.join(FUNANNOTATEDB, "funannotate-db-info.txt")
    params:
        funannotate_tar_url = FUNANNOTATEURL,
        funannotate_sha_url = FUNANNOTATESHAURL,
        funannotate_tar = os.path.join(FUNANNOTATEDB, f"{FUNANNOTATEID}.tar.gz"),
        funannotate_sha = os.path.join(FUNANNOTATEDB, f"{FUNANNOTATEID}.sha256"),
        funannotate_db = FUNANNOTATEDB
    log:
        "logs/funannotate_db.log"
    message:
        "--- Funannotate: Download and verify funannotate database. ---"
    priority: 10
    shell:
        """
        mkdir -p "{params.funannotate_db}"

        if [ ! -f "{params.funannotate_sha}" ]; then
            echo "[funannotate_db] sha file not found, downloading sha and tar.gz files" > {log}
            curl -L --fail -o "{params.funannotate_sha}" "{params.funannotate_sha_url}" >> {log} 2>&1
            curl -L --fail -o "{params.funannotate_tar}" "{params.funannotate_tar_url}" >> {log} 2>&1
        else
            echo "[funannotate_db] sha file exists: {params.funannotate_sha} (skip download)" >> {log}
            if [ ! -f "{params.funannotate_tar}" ]; then
                echo "[funannotate_db] missing, downloading tar.gz only" >> {log}
                curl -L --fail -o "{params.funannotate_tar}" "{params.funannotate_tar_url}" >> {log} 2>&1
            fi
        fi

        tar -xzf "{params.funannotate_tar}" --strip-components=1 -C "{params.funannotate_db}" >> {log} 2>&1
        """


rule funannotate_preprocess:
    input:
        contigs = final_contigs,
        db_info = os.path.join(FUNANNOTATEDB, "funannotate-db-info.txt")
    output:
        contigs_clean = "04.annotation/{sample}/contigs_clean.fasta",
        contigs_sort = "04.annotation/{sample}/contigs_sort.fasta"
    params:
        funannotate_db = FUNANNOTATEDB
    resources:
        cpus = CPUS
    conda:
        "envs/funannotate.yaml"
    message:
        "--- Funannotate: Clean and sort contigs before masking. ---"
    log:
        "logs/funannotate_preprocess_{sample}.log"
    priority: 6
    shell:
        """
        set -euo pipefail

        export FUNANNOTATE_DB="{params.funannotate_db}"

        funannotate clean \
            -i {input.contigs} \
            -o {output.contigs_clean} > {log} 2>&1

        funannotate sort \
            -i {output.contigs_clean} \
            -o {output.contigs_sort} \
            --minlen 0 >> {log} 2>&1
        """

rule repeat_masking:
    input:
        contigs_sort = "04.annotation/{sample}/contigs_sort.fasta"
    output:
        contigs_mask = "04.annotation/{sample}/contigs_mask.fasta"
    params:
        method = MASKING_METHOD,
        work_dir = "04.annotation/{sample}/repeatmasking",
        quick_arg = "-quick" if REPEATMODELER_QUICK else "",
        ltrstruct_arg = "-LTRStruct" if REPEATMODELER_LTRSTRUCT else ""
    threads:
        min(CPUS, 12)
    conda:
        "envs/repeatmasking.yaml"
    message:
        "--- Repeat masking: Softmask contigs. ---"
    log:
        "logs/repeat_masking_{sample}.log"
    priority: 6
    shell:
        """
        set -euo pipefail

        mkdir -p logs
        input_fasta=$(readlink -f {input.contigs_sort})
        output_fasta=$(readlink -f {output.contigs_mask})
        log_file=$(readlink -f {log})
        work_dir="{params.work_dir}"

        rm -rf "$work_dir"
        mkdir -p "$work_dir"

        if [ "{params.method}" = "tantan" ]; then
            tantan "$input_fasta" > "$output_fasta" 2> "$log_file"
        elif [ "{params.method}" = "repeatmodeler_repeatmasker" ]; then
            cd "$work_dir"
            BuildDatabase -name {wildcards.sample}_rm "$input_fasta" > "$log_file" 2>&1
            RepeatModeler -database {wildcards.sample}_rm -threads {threads} {params.quick_arg} {params.ltrstruct_arg} >> "$log_file" 2>&1
            families="{wildcards.sample}_rm-families.fa"
            if [ ! -s "$families" ] && [ -s "consensi.fa.classified" ]; then
                families="consensi.fa.classified"
            fi
            if [ ! -s "$families" ]; then
                echo "RepeatModeler did not produce a usable repeat library." >> "$log_file"
                exit 1
            fi
            RepeatMasker -pa {threads} -xsmall -lib "$families" -dir . "$input_fasta" >> "$log_file" 2>&1
            cp "$(basename "$input_fasta").masked" "$output_fasta"
        fi
        """


