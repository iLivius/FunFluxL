        """


rule iprscan_annotation:
    input:
        funannotate_dir = "04.annotation/{sample}/funannotate"
    output:
        iprscan_out = "04.annotation/{sample}/iprscan/interproscan_out.xml"
    params:
        iprscan = IPRSCAN
    resources:
        # InterProScan benefits from multiple CPUs, but very high values can be
        # inefficient and may put unnecessary pressure on shared systems.
        cpus = min(CPUS, 10)
    conda:
        # Keep InterProScan in its own Java 11 environment. The main
        # funannotate environment can still resolve with Java 8 dependencies.
        "envs/interproscan.yaml"
    message:
        "--- InterProScan: Gene annotation. ---"
    log:
        "logs/iprscan_annotation_{sample}.log"
    priority: 5
    shell:
        """
        # Fail immediately on command errors, unset variables, or broken pipes.
        set -euo pipefail

        # Work with absolute paths where possible, so the rule is robust to
        # Snakemake changing directories internally.
        funannotate_dir=$(readlink -f {input.funannotate_dir})

        # Create the InterProScan output directory before resolving its absolute
        # path. This makes the rule safe on a completely fresh output directory.
        iprscan_dir=$(dirname "{output.iprscan_out}")
        mkdir -p "$iprscan_dir"
        iprscan_dir=$(readlink -f "$iprscan_dir")
        iprscan_xml="$iprscan_dir/$(basename "{output.iprscan_out}")"

        # InterProScan works on predicted proteins. Funannotate normally writes
        # them under predict_results, but update_results is also checked for
        # compatibility with workflows that include a funannotate update step.
        proteins=""
        for results_dir in "$funannotate_dir/predict_results" "$funannotate_dir/update_results"; do
            if [ -d "$results_dir" ]; then
                proteins=$(find "$results_dir" -maxdepth 1 -type f -name "*.proteins.fa" -print -quit)
                if [ -n "$proteins" ]; then
                    break
                fi
            fi
        done

        # Stop here if gene prediction did not produce a protein FASTA. Running
        # InterProScan without a real input would only create a misleading error.
        if [ -z "$proteins" ]; then
            echo "Could not find a *.proteins.fa file in $funannotate_dir/predict_results or update_results." > {log}
            exit 1
        fi

        # Remove any previous XML before the run. A stale file must never be
        # mistaken for a successful InterProScan result.
        rm -f "$iprscan_xml"
        echo "Running InterProScan directly on $proteins" > {log}

        # Run InterProScan directly instead of the funannotate iprscan wrapper.
        # This avoids wrapper-level XML assembly issues with newer InterProScan
        # releases while still producing the XML expected by funannotate annotate.
        "{params.iprscan}" \
            -i "$proteins" \
            -f XML \
            -goterms \
            -pa \
            -cpu {resources.cpus} \
            -o "$iprscan_xml" >> {log} 2>&1

        # Validate the XML before handing it to downstream annotation. This
        # catches empty, truncated, malformed, or wrong-type XML at the source.
        python - "$iprscan_xml" >> {log} 2>&1 <<'PY'
import sys
import xml.etree.ElementTree as ET

# The shell passes the InterProScan XML path as the first Python argument.
path = sys.argv[1]
try:
    # Parse the XML and keep the root element for a type check.
    root = ET.parse(path).getroot()
except Exception as exc:
    sys.stderr.write("InterProScan XML validation failed for %s: %s\\n" % (path, exc))
    sys.exit(1)

# XML namespaces can prefix the tag with a namespace block before protein-matches.
# chr(125) is the closing curly brace; spelling it this way avoids confusing
# Snakemake's own brace-based string formatting.
tag = root.tag.split(chr(125))[-1]
if tag != "protein-matches":
    sys.stderr.write("InterProScan XML validation failed for %s: unexpected root tag '%s'\\n" % (path, root.tag))
    sys.exit(1)
PY
        """


rule antismash_db:
    output:
        antismash_db = temp(directory("04.annotation/antismash_db"))
    conda:
        "envs/antismash.yaml"
    message:
        "--- antiSMASH: Database download. ---"
    log:
        "logs/antismash_db.log"
    priority: 10
    shell:
        """
        download-antismash-databases \
            --database-dir {output.antismash_db} > {log} 2>&1
        """


rule antismash_annotation:
    input:
        antismash_db = "04.annotation/antismash_db",
        funannotate_dir = "04.annotation/{sample}/funannotate"
    output:
        antismash_dir = directory("04.annotation/{sample}/antismash")
    params:
        basename = "antismash",
        genefinding_tool = "none",
        gbk_file = lambda wildcards: os.path.join(
            "04.annotation",
            wildcards.sample,
            "funannotate",
            "predict_results",
            f"{annotations[wildcards.sample]['species_name'].replace(' ', '_')}_{wildcards.sample}.gbk"
        )
    resources:
        cpus = min(CPUS, 12)
    conda:
        "envs/antismash.yaml"
    message:
        "--- antiSMASH: Secondary metabolite prediction. ---"
    log:
        "logs/antismash_annotation_{sample}.log"
    priority: 5
    shell:
        """
        antismash \
            --taxon fungi \
            --output-dir {output.antismash_dir} \
            --output-basename {params.basename} \
            --databases {input.antismash_db} \
            --genefinding-tool {params.genefinding_tool} \
            --cpus {resources.cpus} \
            {params.gbk_file} > {log} 2>&1
        """


rule eggnog_annotation:
    input:
        funannotate_dir = "04.annotation/{sample}/funannotate"
    output:
        temp_dir = temp(directory("04.annotation/{sample}/eggnog/eggnog_tmp")),
        eggnog_dir = directory("04.annotation/{sample}/eggnog")
    params:
        dmnd_db = DMNDDB,
        protein_file = lambda wildcards: os.path.join(
            "04.annotation",
            wildcards.sample,
            "funannotate",
            "predict_results",
            f"{annotations[wildcards.sample]['species_name'].replace(' ', '_')}_{wildcards.sample}.proteins.fa"
        )
    resources:
        cpus = min(CPUS, 12)
    conda:
        "envs/eggnog-mapper.yaml"
    message:
        "--- EggNOG: Functional annotation. ---"
    log:
        "logs/eggnog_annotation_{sample}.log"
    priority: 5
    shell:
        """
        mkdir -p {output.temp_dir} {output.eggnog_dir}
        export GIT_CEILING_DIRECTORIES="$PWD"

        emapper.py \
            -i {params.protein_file} \
            --output_dir {output.eggnog_dir} \
            --cpu {resources.cpus} \
            -m diamond \
            --data_dir {params.dmnd_db} \
            --output {wildcards.sample} \
            --temp_dir {output.temp_dir} \
            --override > {log} 2>&1

        emapper_version=$(python -c 'import importlib.metadata as m; print(m.version("eggnog-mapper"))')
        sed -i "s/^## emapper-v[0-9][^[:space:]]*/## emapper-${{emapper_version}}/" \
            {output.eggnog_dir}/{wildcards.sample}.emapper.annotations
        """


rule funannotate_annotation:
    input:
        funannotate_dir = "04.annotation/{sample}/funannotate",
        iprscan_out = "04.annotation/{sample}/iprscan/interproscan_out.xml",
        eggnog_dir = "04.annotation/{sample}/eggnog",
        antismash_dir = "04.annotation/{sample}/antismash"
    output:
        annotate_complete = "04.annotation/{sample}/.annotation_complete.txt"
    params:
        funannotate_db = FUNANNOTATEDB
    resources:
        cpus = min(CPUS, 12)
    conda:
        "envs/funannotate.yaml"
    message:
        "--- Funannotate: Functional annotation. ---"
    log:
        "logs/funannotate_annotation_{sample}.log"
    priority: 4
    shell:
        """
        set -euo pipefail

        export FUNANNOTATE_DB="{params.funannotate_db}"

        funannotate_dir=$(readlink -f {input.funannotate_dir})
        antismash_gbk=$(readlink -f {input.antismash_dir}/antismash.gbk)
        iprscan_xml=$(readlink -f {input.iprscan_out})
        eggnog_annotations=$(readlink -f {input.eggnog_dir}/{wildcards.sample}.emapper.annotations)
        log_file=$(readlink -f {log})
        complete_file=$(readlink -f {output.annotate_complete})
        annotate_work="$funannotate_dir/annotate_work"

        mkdir -p "$annotate_work"
        cd "$annotate_work"

        funannotate annotate \
            -i "$funannotate_dir" \
            --antismash "$antismash_gbk" \
            --iprscan "$iprscan_xml" \
            --eggnog "$eggnog_annotations" \
            --cpus {resources.cpus} > "$log_file" 2>&1

        if [ -s genome.fixedproducts ]; then
            mkdir -p "$funannotate_dir/annotate_misc"
            mv genome.fixedproducts "$funannotate_dir/annotate_misc/genome.fixedproducts"
        fi

        touch "$complete_file"

        rm -f "$funannotate_dir"/*.log
        rm -f "$annotate_work"/funannotate-annotate.*.log
        rmdir "$annotate_work" 2>/dev/null || true
        """


rule cleanup:
    input:
        annotate_complete = "04.annotation/{sample}/.annotation_complete.txt"
    output:
        cleanup_complete = "04.annotation/{sample}/.cleanup_complete.txt"
    message:
        "--- Cleaning up the output dir. ---"
    log:
        "logs/cleanup_{sample}.log"
    priority: 1
    shell:
        """
        if [ -f {input.annotate_complete} ]; then
            rm -rf 04.annotation/{wildcards.sample}/clean_*
            rm -rf 04.annotation/{wildcards.sample}/*.log
            rm -rf 04.annotation/{wildcards.sample}/genome.fixedproducts
            touch {output.cleanup_complete}
        fi
        """
