        fastq = "01.pre-processing/{sample}_long_filt.fastq"
    output:
        nanoplot_filt_dir = directory("01.pre-processing/read_qc/{sample}/filt_read_qc")
    resources:
        cpus = min(CPUS, 8)
    conda:
        "envs/nanoplot.yaml"
    message:
        "--- NanoPlot: QC of filtered long reads. ---"
    log:
        "logs/filtered_read_qc_{sample}.log"
    priority: 15
    shell:
        """
        NanoPlot \
            --fastq {input.fastq} \
            --threads {resources.cpus} \
            --loglength \
            --prefix "{wildcards.sample}_" \
            --outdir {output.nanoplot_filt_dir} > {log} 2>&1
        """


rule assembly:
    input:
        filt_long = "01.pre-processing/{sample}_long_filt.fastq"
    output:
        flye_dir = directory("02.assembly/{sample}"),
        flye_contigs = "02.assembly/{sample}/assembly.fasta",
        flye_contigs_lin = "02.assembly/{sample}/assembly_linearized.fasta"
    params:
        input_mode = flye_input_mode_arg,
        iterations = 5
    resources:
        cpus = CPUS
    conda:
        "envs/flye.yaml"
    message:
        "--- Flye: Genome assembly with long reads. ---"
    log:
        "logs/genome_assembly_{sample}.log"
    priority: 14
    shell:
        """
        flye \
            {params.input_mode} {input.filt_long} \
            --out-dir {output.flye_dir} \
            --threads {resources.cpus} \
            --iterations {params.iterations} > {log} 2>&1

        awk {FASTA_LIN_CMD:q} {output.flye_contigs} > {output.flye_contigs_lin}
        """


rule map_contigs:
    input:
        filt_long = "01.pre-processing/{sample}_long_filt.fastq",
        flye_contigs = "02.assembly/{sample}/assembly.fasta"
    output:
        bam = "03.post-processing/contaminants/{sample}_map.bam",
        bai = "03.post-processing/contaminants/{sample}_map.bam.bai"
    params:
        preset = minimap_preset
    resources:
        cpus = CPUS
    conda:
        "envs/minimap.yaml"
    message:
        "--- Minimap2: Map long reads against contigs. ---"
    log:
        "logs/map_contigs_{sample}.log"
    priority: 13
    shell:
        """
        minimap2 \
            -ax {params.preset} \
            {input.flye_contigs} \
            {input.filt_long} 2> {log} | \
        samtools view \
            -S -b -u \
            -@ {resources.cpus} | \
        samtools sort \
            -o {output.bam} \
            -@ {resources.cpus} 2>> {log}

        samtools index {output.bam} -@ {resources.cpus} 2>> {log}
        """


rule map_qc:
    input:
        bam = "03.post-processing/contaminants/{sample}_map.bam",
        bai = "03.post-processing/contaminants/{sample}_map.bam.bai"
    output:
        qualimap_dir = directory("03.post-processing/mapping_evaluation/{sample}")
    resources:
        java_mem = min(RAM, 64),
        threads = min(CPUS, 24)
    conda:
        "envs/qualimap.yaml"
    message:
        "--- Qualimap: Mapping evaluation. ---"
    log:
        "logs/map_qc_{sample}.log"
    priority: 12
    shell:
        """
        qualimap bamqc \
            -bam {input.bam} \
            --java-mem-size={resources.java_mem}G \
            -nt {resources.threads} \
            -outdir {output.qualimap_dir} \
            -outformat html > {log} 2>&1
        """


rule blast_contigs:
    input:
        flye_contigs = "02.assembly/{sample}/assembly.fasta"
    output:
        blast = "03.post-processing/contaminants/{sample}/blastout"
    params:
        dir = BLASTDB,
        db = os.path.join(BLASTDB, config.get("parameters", {}).get("nt_version", "core_nt"))
    resources:
        cpus = min(CPUS, 24)
    conda:
        "envs/blast.yaml"
    message:
        "--- BLAST: Contigs against NCBI nt db. ---"
    log:
        "logs/blast_contigs_{sample}.log"
    priority: 13
    shell:
        """
        BLASTDB={params.dir} \
        blastn \
            -task megablast \
            -query {input.flye_contigs} \
            -db {params.db} \
            -outfmt '6 qseqid staxids bitscore pident evalue length qlen slen qcovs qcovhsp sskingdoms scomnames sscinames sblastnames stitle' \
            -num_threads {resources.cpus} \
            -evalue 1e-5 \
            -max_target_seqs 50 \
            -max_hsps 5 \
            -out {output.blast} > {log} 2>&1
        """


rule blob_json:
