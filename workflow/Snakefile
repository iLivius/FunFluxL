# Default config. A user-supplied --configfile replaces this when launching.
configfile: 'config/config.yaml'

# Python is used here to validate inputs, parse metadata, and decide long-read
# branches before Snakemake builds the rule graph.
import os
import sys
import pandas as pd
from urllib.parse import urlparse, unquote

# Sample names become filenames, report labels, and Funannotate IDs. These
# characters make those names ambiguous or unsafe.
not_allowed_chars = set("_*#@%^/! ?&:;|<>")

# Resolve databases, files, and input/output directories once. The rules below
# use these short names instead of repeated config lookups.
workdir: config['directories']['output_dir']
FUNANNOTATEURL = config['links']['funannotate_link']
UNITEURL = config.get('links', {}).get('unite_its_link', '')
INPUTDIR = config['directories']['input_dir']
BLASTDB = config['directories']['blast_db']
DMNDDB = config['directories']['eggnog_db']
FUNANNOTATEDB = config['directories']['funannotate_db']
GENEMARKDIR = config['directories']['genemark_dir']
IPRSCAN = config['files']['iprscan']
ANNOTATION = config['files']['annotation_params']

# Global resources and helper paths. Rules can still cap CPU use for individual
# programs that do not scale well.
CPUS = config['resources']['threads']
RAM = config['resources']['ram_gb']
WORKFLOW_DIR = workflow.basedir
PARAMETERS = config.get('parameters', {}) or {}

# Store the downloaded UNITE ITS database inside the output tree, next to the
# ITS extraction outputs that use it.
UNITE_FASTA = "03.post-processing/ITS_extraction/unite_its_sintax.fasta"
ITS_TAXONOMY_CUTOFF = float(PARAMETERS.get("its_taxonomy_cutoff", 0.8))
MASKING_METHOD = str(PARAMETERS.get("masking_method", "tantan")).strip().lower()

# Shared helper used after BlobTools. It reads contig taxonomy assignments and
# decides which contigs are kept, discarded, or left untouched.
SELECT_TAXONOMY_SCRIPT = os.path.join(WORKFLOW_DIR, "scripts", "select_contigs_by_taxonomy.py")

# Read boolean-like config values explicitly. This keeps masking flags stable
# whether the user writes true, TRUE, yes, or on.
def _config_bool(value, default=False):
    if value is None:
        return default
    if isinstance(value, bool):
        return value
    text = str(value).strip().lower()
    if text in {"true", "1", "yes", "on"}:
        return True
    if text in {"false", "0", "no", "off"}:
        return False
    raise ValueError(f"Invalid boolean config value: {value!r}")

# RepeatModeler options are normalized once here; the masking rule receives
# simple true/false values.
REPEATMODELER_QUICK = _config_bool(PARAMETERS.get("repeatmodeler_quick", True), True)
REPEATMODELER_LTRSTRUCT = _config_bool(PARAMETERS.get("repeatmodeler_ltrstruct", False), False)

# Masking changes the sequence passed to prediction. Reject unknown strategies
# before any rule starts.
if MASKING_METHOD not in {"tantan", "repeatmodeler_repeatmasker"}:
    raise ValueError(
        "Invalid masking_method. Expected one of: tantan, "
        "repeatmodeler_repeatmasker."
    )

# ITS classification requires a UNITE download link.
if not UNITEURL:
    raise ValueError("links.unite_its_link is missing.")

# Shared awk command for linearizing FASTA records before tools that prefer one
# sequence line per contig.
FASTA_LIN_CMD = r"""{if(NR==1) {printf "%s\n", $0} else {if(/^>/) {printf "\n%s\n", $0} else {printf $0}}}"""


# Convert optional decontamination settings to plain text for the selector
# script.
def _as_decontam_text(value):
    if value is None:
        return ""
    if isinstance(value, (list, tuple, set)):
        return ";".join(str(item).strip() for item in value if str(item).strip())
    return str(value).strip()


# Normalize decontamination settings. The fungal default is off, but the same
# include/exclude/auto selector can be enabled when needed.
def _decontam_settings(default_mode):
    params = config.get("parameters", {}) or {}
    settings = dict(params.get("decontamination") or {})
    if not settings:
        legacy_genus = params.get("genus", None)
        if legacy_genus is not None and str(legacy_genus).strip():
            settings = {"mode": "include", "include_genera": legacy_genus}
        elif "genus" in params:
            settings = {"mode": "auto"}
        else:
            settings = {"mode": default_mode}

    mode = str(settings.get("mode", default_mode) or default_mode).strip().lower()
    if mode not in {"auto", "include", "exclude", "off"}:
        raise ValueError("Invalid decontamination.mode. Expected one of: auto, include, exclude, off.")
    settings["mode"] = mode
    settings["include_genera"] = _as_decontam_text(settings.get("include_genera", ""))
    settings["include_genera_by_sample"] = _as_decontam_text(settings.get("include_genera_by_sample", ""))
    settings["exclude_genera"] = _as_decontam_text(settings.get("exclude_genera", ""))
    settings["exclude_genera_file"] = _as_decontam_text(settings.get("exclude_genera_file", ""))
    settings["sample_overrides"] = _as_decontam_text(settings.get("sample_overrides", ""))
    settings["discard_no_hit"] = str(_config_bool(settings.get("discard_no_hit"), False)).lower()
    return settings


# The selected decontamination policy is printed once so the run log records
# whether contigs can be discarded.
DECONTAMINATION = _decontam_settings("off")
print(
    "Decontamination mode: "
    f"{DECONTAMINATION['mode']} (discard_no_hit={DECONTAMINATION['discard_no_hit']})."
)


# Read the annotation table used by Funannotate. Every sample needs species
# text, protein evidence, and an AUGUSTUS model.
def parse_annotation_file(annotation_file):
    if not os.path.exists(annotation_file):
        raise FileNotFoundError(f"Annotation file '{annotation_file}' not found.")

    annotations = {}
    with open(annotation_file, 'r') as f:
        for line in f:
            line = line.strip()
            if line.startswith("#") or not line:
                continue

            fields = line.split("\t")
            if len(fields) != 4:
                raise ValueError(f"Line '{line}' is not formatted correctly.")

            sample, species, protein_file, augustus_model = fields

            # Protein evidence must be present and non-empty before Funannotate
            # is scheduled.
            if not os.path.exists(protein_file):
                sys.stderr.write(f"Error: Protein file '{protein_file}' for sample '{sample}' does not exist.\n")
                sys.exit(1)

            if os.path.getsize(protein_file) == 0:
                sys.stderr.write(f"Error: Protein file '{protein_file}' for sample '{sample}' is empty.\n")
                sys.exit(1)

            annotations[sample] = {
                'species_name': species,
                'protein_file': protein_file,
                'augustus_model': augustus_model
            }

    return annotations


# Parse metadata before discovering samples so missing rows are caught early.
annotations = parse_annotation_file(ANNOTATION)

# Discover long-read files. Suffix decides the technology:
# sample_ont.ext uses ONT logic; sample_pacbio.ext uses PacBio HiFi logic.
READ_SUFFIXES = ("ont", "pacbio")
LONG_READ_FASTQS = {}
READ_TYPES = {}
EXTENSIONS = []

# A sample must not appear as both ONT and PacBio. Mixed technologies for the
# same sample would make Flye and polishing choices undefined.
for read_type in READ_SUFFIXES:
    samples, extensions = glob_wildcards(os.path.join(INPUTDIR, f'{{sample}}_{read_type}.{{extn}}'))
    for sample, extension in zip(samples, extensions):
        if sample in LONG_READ_FASTQS:
            previous_type = READ_TYPES[sample]
            sys.stderr.write(
                f"Sample '{sample}' has both _{previous_type} and _{read_type} FASTQ inputs. "
                "Provide only one long-read technology per sample.\n"
            )
            sys.exit(1)

        LONG_READ_FASTQS[sample] = os.path.join(INPUTDIR, f"{sample}_{read_type}.{extension}")
        READ_TYPES[sample] = read_type
        EXTENSIONS.append(extension)

SAMPLES = sorted(LONG_READ_FASTQS)

# Stop before rule execution if there are no long-read inputs or if a sample
# name would create unsafe paths.
if len(SAMPLES) == 0:
    sys.stderr.write(f"No long-read FASTQ files ending in _ont or _pacbio found in {INPUTDIR}. Please, check directory.\n")
    sys.exit(1)
else:
    for sample in SAMPLES:
        if any(char in sample for char in not_allowed_chars):
            sys.stderr.write(f"Sample name '{sample}' contains not allowed characters.\n")
            sys.exit(1)
        print(f"Sample {sample} in process ({READ_TYPES[sample]} reads)...")

# Require one FASTQ extension across the batch so wildcard paths stay simple.
for extension in EXTENSIONS:
    if extension.endswith(("fastq", "fq", "fastq.gz", "fq.gz")):
        if len(set(EXTENSIONS)) != 1:
            sys.stderr.write("More than one type of file extension detected\n\t")
            sys.stderr.write("\n\t".join(set(EXTENSIONS)))
            sys.exit(1)
    else:
        sys.stderr.write("\nFile format not recognized.\n")
        sys.exit(1)

# Every sequenced sample must also appear in the annotation metadata table.
CHECK_SAMPLES = []
for sample in SAMPLES:
    if sample not in annotations:
        sys.stderr.write(f"Sample name '{sample}' not found in annotation file.\n")
        sys.exit(1)
    CHECK_SAMPLES.append(sample)

ONT_SAMPLES = [sample for sample in CHECK_SAMPLES if READ_TYPES[sample] == "ont"]
PACBIO_SAMPLES = [sample for sample in CHECK_SAMPLES if READ_TYPES[sample] == "pacbio"]


# Extract a stable database ID from an archive URL.
def id_from_url(url: str) -> str:
    path = unquote(urlparse(url).path)
    filename = os.path.basename(path)
    if not filename:
        raise ValueError(f"Cannot parse filename from URL: {url}")

    if filename.endswith(".tar.gz"):
        return filename[:-len(".tar.gz")]
    if filename.endswith(".tgz"):
        return filename[:-len(".tgz")]

    return os.path.splitext(filename)[0]


# Funannotate database link is required because the workflow also derives the
# matching checksum URL from it.
if FUNANNOTATEURL:
    FUNANNOTATEID = id_from_url(FUNANNOTATEURL)
else:
    raise ValueError("The funannotate database link is missing or empty.")


# Extract the Zenodo record number from a standard records/<id>/files URL.
def zenodo_record_from_url(url: str) -> str:
    path = urlparse(url).path.strip("/")
    parts = path.split("/")

    if len(parts) >= 3 and parts[0] == "records":
        return parts[1]

    raise ValueError(f"Cannot infer Zenodo record ID from URL: {url}")


# The checksum URL is built once and reused by the database setup rule.
ZENODORECORD = zenodo_record_from_url(FUNANNOTATEURL)
FUNANNOTATESHAURL = (
    f"https://zenodo.org/records/{ZENODORECORD}/files/"
    f"{FUNANNOTATEID}.sha256?download=1"
)

# False-like Medaka values mean "do not run consensus polishing".
def _is_false(value):
    if isinstance(value, bool):
        return value is False
    if value is None:
        return False
    return str(value).strip().lower() in {"false", "0", "no", "off", "none"}


# A real model name is anything that is not auto, true, empty, or false-like.
def _has_explicit_medaka_model(value):
    if isinstance(value, bool) or value is None:
        return False
    return str(value).strip().lower() not in {"", "true", "1", "yes", "on", "auto", "false", "0", "no", "off", "none"}


params = config.get("parameters", {}) or {}
MEDAKA_MODEL = params.get("medaka_model", None)
FLYE_INPUT_MODE = params.get("flye_input_mode", "auto")

# Empty Flye mode is treated as automatic.
if FLYE_INPUT_MODE is None or str(FLYE_INPUT_MODE).strip() == "":
    FLYE_INPUT_MODE = "auto"

# User-facing mode names mapped to Flye flags.
FLYE_MODE_KEY = str(FLYE_INPUT_MODE).strip().lower()
FLYE_MODE_MAP = {
    "nano-raw": "--nano-raw",
    "nano-hq": "--nano-hq",
    "pacbio-hifi": "--pacbio-hifi",
}

if FLYE_MODE_KEY not in {"auto", *FLYE_MODE_MAP.keys()}:
    raise ValueError("Invalid 'flye_input_mode' parameter. Expected one of: auto, nano-raw, nano-hq, pacbio-hifi.")

# For ONT, automatic mode defaults to --nano-hq unless an explicit fast Medaka
# model suggests older/noisier reads. PacBio samples override this later.
if FLYE_MODE_KEY == "auto":
    if _has_explicit_medaka_model(MEDAKA_MODEL) and "fast" in str(MEDAKA_MODEL).lower():
        FLYE_INPUT_MODE_ARG = "--nano-raw"
        if ONT_SAMPLES:
            print("Flye input mode set automatically to '--nano-raw' for ONT samples based on the explicit Medaka fast model.")
    else:
        FLYE_INPUT_MODE_ARG = "--nano-hq"
        if ONT_SAMPLES:
            print("Flye input mode set automatically to '--nano-hq' for ONT samples.")
else:
    FLYE_INPUT_MODE_ARG = FLYE_MODE_MAP[FLYE_MODE_KEY]
    if ONT_SAMPLES:
        print(f"Flye input mode overridden via config for ONT samples with value: '{FLYE_INPUT_MODE_ARG}'.")

# Resolve the raw long-read FASTQ path for each sample.
def raw_long_fastq(wildcards):
    return LONG_READ_FASTQS[wildcards.sample]


# Return the technology detected from the filename suffix.
def sample_read_type(sample):
    return READ_TYPES[str(sample)]


# PacBio HiFi always uses Flye --pacbio-hifi. ONT uses the configured or
# inferred ONT mode.
def flye_input_mode_arg(wildcards):
    if sample_read_type(wildcards.sample) == "pacbio":
        return "--pacbio-hifi"
    return FLYE_INPUT_MODE_ARG


# Minimap2 needs a different preset for HiFi reads than for ONT reads.
def minimap_preset(wildcards):
    if sample_read_type(wildcards.sample) == "pacbio":
        return "map-hifi"
    return "map-ont"


# Medaka is ONT-only here. PacBio HiFi samples are already high accuracy and
# must skip Medaka even if the config contains a model.
def use_medaka(sample):
    return sample_read_type(sample) == "ont" and FLYE_INPUT_MODE_ARG != "--pacbio-hifi" and not _is_false(MEDAKA_MODEL)


# Only these samples get consensus-polishing targets.
MEDAKA_SAMPLES = [sample for sample in CHECK_SAMPLES if use_medaka(sample)]

# Make the PacBio decision visible in the run log.
if PACBIO_SAMPLES:
    print("PacBio HiFi samples detected from _pacbio FASTQ suffix: " + ", ".join(PACBIO_SAMPLES))
    print("PacBio HiFi samples will use Flye '--pacbio-hifi' and skip Medaka polishing.")

# Report the final Medaka decision before rules are evaluated.
if not MEDAKA_SAMPLES:
    if _is_false(MEDAKA_MODEL):
        print("Medaka disabled via config. Skipping consensus polishing.")
    else:
        print("No samples are eligible for Medaka polishing; any configured 'medaka_model' value is ignored.")
elif _is_false(MEDAKA_MODEL):
    print("Medaka disabled via config. Skipping consensus polishing.")
elif _has_explicit_medaka_model(MEDAKA_MODEL):
    print(f"The 'medaka_model' parameter is specified with value: '{MEDAKA_MODEL}'.")
else:
    print("Medaka model will be inferred automatically from FASTQ headers.")


# Downstream rules use this helper to get the correct assembly path, with or
# without Medaka.
def final_contigs(wildcards):
    if use_medaka(wildcards.sample):
        return f"03.post-processing/consensus/{wildcards.sample}/consensus.fasta"
    return f"03.post-processing/contaminants/{wildcards.sample}/assembly_decontam.fasta"


# Rule all includes Medaka consensus targets only for eligible ONT samples.
FINAL_CONTIGS_TARGETS = expand(
    "03.post-processing/consensus/{sample}/consensus.fasta",
    sample=MEDAKA_SAMPLES
)


rule all:
    input:
        filt_long = expand("01.pre-processing/{sample}_long_filt.fastq", sample=CHECK_SAMPLES),
        nanoplot_raw_dir = expand("01.pre-processing/read_qc/{sample}/raw_read_qc", sample=CHECK_SAMPLES),
        nanoplot_filt_dir = expand("01.pre-processing/read_qc/{sample}/filt_read_qc", sample=CHECK_SAMPLES),
        flye_contigs = expand("02.assembly/{sample}/assembly.fasta", sample=CHECK_SAMPLES),
        flye_contigs_lin = expand("02.assembly/{sample}/assembly_linearized.fasta", sample=CHECK_SAMPLES),
        qualimap_dir = expand("03.post-processing/mapping_evaluation/{sample}", sample=CHECK_SAMPLES),
        bestscore = expand("03.post-processing/contaminants/{sample}/bestscore.blob.blobDB.table.txt", sample=CHECK_SAMPLES),
        abund = expand("03.post-processing/contaminants/{sample}/{sample}_composition.txt", sample=CHECK_SAMPLES),
        contigs = expand("03.post-processing/contaminants/{sample}/assembly_decontam.fasta", sample=CHECK_SAMPLES),
        final_contigs = FINAL_CONTIGS_TARGETS,
        busco_dir = expand("03.post-processing/completeness_evaluation/{sample}", sample=CHECK_SAMPLES),
        full = expand("03.post-processing/ITS_extraction/{sample}/{sample}.full.fasta", sample=CHECK_SAMPLES),
        its1 = expand("03.post-processing/ITS_extraction/{sample}/{sample}.ITS1.fasta", sample=CHECK_SAMPLES),
        its2 = expand("03.post-processing/ITS_extraction/{sample}/{sample}.ITS2.fasta", sample=CHECK_SAMPLES),
        summary = expand("03.post-processing/ITS_extraction/{sample}/{sample}.summary.txt", sample=CHECK_SAMPLES),
        its1_tax = expand("03.post-processing/ITS_extraction/{sample}/{sample}_ITS1_taxonomy.txt", sample=CHECK_SAMPLES),
        its2_tax = expand("03.post-processing/ITS_extraction/{sample}/{sample}_ITS2_taxonomy.txt", sample=CHECK_SAMPLES),
        multiqc_dir = "report",
        funannotate_db_info = os.path.join(FUNANNOTATEDB, "funannotate-db-info.txt"),
        funannotate_dir = expand("04.annotation/{sample}/funannotate", sample=CHECK_SAMPLES),
        contigs_clean = expand("04.annotation/{sample}/contigs_clean.fasta", sample=CHECK_SAMPLES),
        contigs_sort = expand("04.annotation/{sample}/contigs_sort.fasta", sample=CHECK_SAMPLES),
        contigs_mask = expand("04.annotation/{sample}/contigs_mask.fasta", sample=CHECK_SAMPLES),
        iprscan_out = expand("04.annotation/{sample}/iprscan/interproscan_out.xml", sample=CHECK_SAMPLES),
        eggnog_dir = expand("04.annotation/{sample}/eggnog", sample=CHECK_SAMPLES),
        antismash_dir = expand("04.annotation/{sample}/antismash", sample=CHECK_SAMPLES),
        cleanup_complete = expand("04.annotation/{sample}/.cleanup_complete.txt", sample=CHECK_SAMPLES)


rule filter_reads:
    input:
        long = raw_long_fastq
    output:
        filt_long = "01.pre-processing/{sample}_long_filt.fastq"
    params:
        min_length = 1000,
        keep_percent = 90,
        target_bases = 500000000
    conda:
        "envs/filtlong.yaml"
    message:
        "--- Filtlong: Filter long reads. ---"
    log:
        "logs/filter_reads_{sample}.log"
    priority: 16
    shell:
        """
        filtlong \
            --min_length {params.min_length} \
            --keep_percent {params.keep_percent} \
            --target_bases {params.target_bases} \
            {input.long} > {output.filt_long} 2>{log}
        """


rule raw_read_qc:
    input:
        fastq = raw_long_fastq
    output:
        nanoplot_raw_dir = directory("01.pre-processing/read_qc/{sample}/raw_read_qc")
    resources:
        cpus = min(CPUS, 8)
    conda:
        "envs/nanoplot.yaml"
    message:
        "--- NanoPlot: QC of raw long reads. ---"
    log:
        "logs/raw_read_qc_{sample}.log"
    priority: 16
    shell:
        """
        NanoPlot \
            --fastq {input.fastq} \
            --threads {resources.cpus} \
            --loglength \
            --prefix "{wildcards.sample}_" \
            --outdir {output.nanoplot_raw_dir} > {log} 2>&1
        """


rule filtered_read_qc:
